@startuml
'https://plantuml.com/class-diagram
skinparam linetype ortho

package "Dashboard Layer" {
    class DashboardGrid {
        +handleConnectRobot(robotId: string): Promise<void>
        +handleDisconnectRobot(robotId: string): void
        +handleAddWidget(type, robotId?, config?): void
        +handleRemoveWidget(widgetId: string): void
        +handleAddTab(tabName: string): void
        +handleSave(): void
    }

    class WidgetFactory {
        +renderWidget(widgetConfig: WidgetConfig): ReactElement | null
    }

    abstract class WidgetComponent {
        -widgetConfig: WidgetConfig
        +render(): ReactElement
    }

    struct WidgetConfig {
        +id: string
        +type: WidgetType
        +position: WidgetPositionConfig
        +connectors: RobotConnector[]
        +...others
    }

    struct DashboardConfig {
        + id: string
        + name: string
        + widgets: WidgetConfig[]
    }

    struct WidgetPositionConfig {
        +x: number
        +y: number
        +w: number
        +h: number
    }

    struct RobotConnector {
        +robotId: string
        +connectorId: string
    }

    struct RobotConfig {
        +id: string
        +name: string
        +connectors: ConnectorConfig[]
    }

    note top of RobotConfig
      어디 저장할진 미정,
      아마 백엔드에서 가져와서 Zustand 에 저장해둘 듯
    end note

    struct ConnectorConfig {
        +connectorId: string
        +dataType: string
        +params: any
    }
}

package "Channel Manager" {
    class ChannelManager {
        <<Zustand Store>>
        -activeChannels: Map<string, Map<string, ChannelInfo>>
        -channelRequirements: Map<string, ChannelRequirement[]>
        +registerActiveChannel(channelInfo): void
        +getAllActiveChannels(robotId: string): ChannelInfo[]
        +addChannelRequirement(channelRequirement): void
        +removeChannelRequirement(channelRequirement): void
        +getChannelRequirements(robotId: string): ChannelRequirement[]
        +onCallbackRegistered(robotId, channelLabel, callback): void
    }

    note bottom of ChannelManager
        activeChannels 의 key 및 value map 의 key 가 뭔지 모르겠음
    end note

    interface ChannelInfo {
        + channelType: "datachannel" | "mediastream"
        + robotConnector: RobotConnector
        + rtcConnection: WebRTCConnection
        + rtcDataChannel?: RTCDataChannel
        + mediaStream?: MediaStream
    }

    interface ChannelRequirement {
        + store: MosaicStore
        + robotConnector: RobotConnector
    }
}

package "Store Layer" {
    class RobotConnectorRefMap<V> {
        -map: Map<string, V>
        -refCounts: Map<string, number>
        -serializeKey(robotConnector: RobotConnector): string
        -deserializeKey(key: string): RobotConnector
        +get(key: RobotConnector): V | undefined
        +set(key: RobotConnector, value: V): void
        +getRefCount(key: RobotConnector): number
        +delete(key: RobotConnector): void
    }

    class StoreManager {
        <<Zustand Store>>
        -mosaicStores: RobotConnectorRefMap<MosaicStore>
        -robotConfigs: Map<string, RobotConfig>
        +setRobotConfigs(robotConfigs: RobotConfig[]): void
        +getRobotConfig(robotId: string): RobotConfig | undefined
        +getOrCreateStore(robotConnector: RobotConnector): ReadableStore | WritableStore
        +releaseStore(robotConnector: RobotConnector): void
        -resolveConnectorType(robotConnector: RobotConnector): string
    }

    note bottom of StoreManager
        RobotConnector 하나당 Store 하나 매핑
    end note

    class StoreFactory {
        -storeFactories: Map<string, (robotConnector) => MosaicStore>
        +registerReadableStore<T extends ReadableStore>(): void
        +registerWritableStore<T extends WritableStore>(): void
        +createStore(connectorType: string, robotConnector): MosaicStore | null
    }
    note bottom of StoreFactory
        connectorType 이 Map 의 Key
    end note

    abstract class MosaicStore {
        #{static}dataType: string
        #robotConnector: RobotConnector
        +MosaicStore(robotConnector: RobotConnector)
        +{static}getDataType(): string
        +{abstract}getStoreType(): "readable" | "writable" | "media"
        +getRobotConnector(): RobotConnector
        +{abstract}beforeConnected(): void
        +{abstract}afterConnected(): void
        +{abstract}afterDisconnected(): void
    }

    abstract class ReadableStore extends MosaicStore {
        -subscriberList: Map<string, Subscriber>
        +getStoreType(): "readable"
        +subscribe(subscriber: (data: ArrayBuffer) => void): UnsubscribeFunction
        +notifySubscribers(data: ArrayBuffer): void
        +{abstract}onSubscriberAdded(subscriber): void
        +{abstract}onSubscriberRemoved(subscriber): void
        -removeSubscriber(subscriberId: string): void
    }

    abstract class WritableStore<V> extends MosaicStore {
        +getStoreType(): "writable"
        +{abstract}add(data: V): void
        #sendData(data: string): void
        +setDataChannel(channel: RTCDataChannel): void
    }

    abstract class MediaStreamStore extends MosaicStore {
        +getStoreType(): "media"
        +{abstract}setMediaStream(stream: MediaStream): void
    }

    class ConnectionCheckingStore extends ReadableStore, WritableStore {
        +{static} dataType: "connection_check"
        -intervalId: number | null
        +afterConnected(): void
        +afterDisconnected(): void
        -connectionCheckInterval(): void
        -replyCheck(data: ArrayBuffer): void
    }
}

package "WebRTC Layer" {
    class WebRTCConnectionManager {
        -connections: Map<string, WebRTCConnection>
        +createConnection(robotId: string): Promise<void>
        +disconnectConnection(robotId: string): void
        +getConnection(robotId: string): WebRTCConnection | undefined
        +onCallbackRegistered(robotId, channelLabel, callback): void
        +removeDataChannel(robotId, channelLabel): void
        -setupDataChannels(robotId, connection): void
    }

    class WebRTCConnection {
        -peerConnection: RTCPeerConnection | null
        -dataChannels: Map<string, RTCDataChannel>
        -callbacks: Map<string, (data: ArrayBuffer) => void>
        +startConnection(): Promise<void>
        +disconnect(): void
        +setCallback(channelLabel: string, callback: (data: ArrayBuffer) => void): void
        +removeCallback(channelLabel: string): void
        +sendData(channelLabel: string, data: ArrayBuffer): void
        +getPeerConnection(): RTCPeerConnection | null
        -createPeerConnection(): RTCPeerConnection
        -setupDataChannel(dataChannel, robotId): void
    }
}

package "WebSocket Layer" {
    class WSConnectionManager {
        <<Zustand Store>>
        -wsConnections: Map<string, boolean>
        +registerConnection(robotId: string): void
        +unregisterConnection(robotId: string): void
        +isConnected(robotId: string): boolean
        +getAllConnections(): Map<string, boolean>
    }
}

' Relationships
DashboardGrid --> ChannelManager : requestConnection()
DashboardGrid --> WidgetFactory : renderWidget()
WidgetFactory --> WidgetComponent : renders
WidgetConfig -* WidgetComponent
DashboardConfig -* DashboardGrid

DashboardConfig *-- WidgetConfig
RobotConfig *-- ConnectorConfig
WidgetConfig *-- RobotConnector
WidgetConfig *-- WidgetPositionConfig

WidgetComponent --> StoreManager : getOrCreateStore()\nreleaseStore()
StoreManager --> StoreFactory : uses
WidgetComponent -> ChannelManager : addChannelRequirement()\nremoveChannelRequirement()

StoreManager *- RobotConnectorRefMap

StoreFactory --> MosaicStore : creates

ChannelManager --> WebRTCConnectionManager : onCallbackRegistered()\nonCallbackUnregistered()
WebRTCConnectionManager --> WebRTCConnection : creates/manages
WebRTCConnectionManager --> ChannelManager : getChannelRequirements()

WebRTCConnection --> ChannelManager : registerActiveChannel()

DashboardGrid --> WSConnectionManager : WS 연결 상태 조회
WebRTCConnectionManager --> WSConnectionManager : WS 연결 상태 조회

ChannelManager *-- ChannelInfo
ChannelManager *-- ChannelRequirement
@enduml